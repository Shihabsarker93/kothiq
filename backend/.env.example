# Which backend to use for ASR:
#   "mlx"    - Apple Silicon GPU-accelerated Whisper (fast; Macs only, recommended on Mac)
#   "local"  - faster-whisper in-process on CPU (free, but slow on Apple Silicon)
#   "colab"  - free self-hosted Whisper via backend/colab_server.ipynb (GPU)
#   "openai" - Whisper API (paid)
ASR_PROVIDER=mlx
MLX_WHISPER_REPO=mlx-community/whisper-large-v3-mlx

# Which backend to use for TTS: "local" (free, self-hosted in-process), "colab"
# (free via backend/colab_server.ipynb), or "google" (Cloud TTS, paid)
TTS_PROVIDER=local

# Whisper model size when ASR_PROVIDER=local (tiny/base/small/medium/large-v3;
# bigger = more accurate but slower on CPU)
WHISPER_MODEL_SIZE=small

# OpenAI — used for ASR (Whisper API) when ASR_PROVIDER=openai
OPENAI_API_KEY=

# Google Gemini — used for the LLM/reasoning layer (always rented, see CLAUDE.md)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud — used for TTS (Text-to-Speech API) when TTS_PROVIDER=google
# This is a SEPARATE credential from GEMINI_API_KEY above (different product).
# Create a GCP project, enable the "Cloud Text-to-Speech API", create a service
# account, download its JSON key, and point this at the file path.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
TTS_VOICE_NAME=bn-IN-Wavenet-A

# Free self-hosted ASR/TTS via Colab — run backend/colab_server.ipynb, paste the
# printed URL here (same URL for both). Changes every time the notebook restarts.
COLAB_ASR_URL=
COLAB_TTS_URL=
